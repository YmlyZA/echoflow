ECHOFLOW_API_KEY=dev-key
ECHOFLOW_PORT=8787

# Provider selection:
# - ASR real-time streaming adapters are not implemented yet; keep fake for local dev.
# - Translation supports fake and volcengine.
ECHOFLOW_ASR_PROVIDER=fake
ECHOFLOW_TRANSLATION_PROVIDER=fake

# Volcengine machine translation large-model API.
# Required when ECHOFLOW_TRANSLATION_PROVIDER=volcengine.
# VOLCENGINE_API_KEY=
# VOLCENGINE_TRANSLATION_ENDPOINT=https://openspeech.bytedance.com/api/v3/machine_translation/matx_translate
# VOLCENGINE_TRANSLATION_RESOURCE_ID=volc.speech.mt
