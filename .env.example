# EchoFlow backend configuration. Copy to `.env` and fill in real credentials.
# Provider secrets live only here (backend env) — never in the extension.

ECHOFLOW_API_KEY=dev-key
ECHOFLOW_PORT=8787

# Provider selection. Default to fake for offline/local dev.
#   ASR:         fake | volcengine  (大模型流式语音识别 / sauc bigmodel)
#   Translation: fake | volcengine  (机器翻译大模型)
ECHOFLOW_ASR_PROVIDER=fake
ECHOFLOW_TRANSLATION_PROVIDER=fake

# --- Volcengine streaming ASR (大模型流式语音识别 / sauc bigmodel) ---
# To enable: set ECHOFLOW_ASR_PROVIDER=volcengine above, then fill these.
# NOTE: ASR credentials are an appid + access token — DIFFERENT from the
# translation VOLCENGINE_API_KEY below (which is a single key).
# VOLCENGINE_ASR_APP_KEY=
# VOLCENGINE_ASR_ACCESS_KEY=
# VOLCENGINE_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# VOLCENGINE_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel

# --- Volcengine machine translation (机器翻译大模型) ---
# To enable: set ECHOFLOW_TRANSLATION_PROVIDER=volcengine above, then fill this.
# VOLCENGINE_API_KEY=
# VOLCENGINE_TRANSLATION_ENDPOINT=https://openspeech.bytedance.com/api/v3/machine_translation/matx_translate
# VOLCENGINE_TRANSLATION_RESOURCE_ID=volc.speech.mt

# Interpretation mode (豆包同声传译 / AST) — separately subscribed; resource volc.service_type.10053
# New-console auth: a SINGLE API Key (sent as X-Api-Key) — NOT the ASR app-id/access-key pair.
VOLCENGINE_AST_API_KEY=
# Optional overrides:
# VOLCENGINE_AST_RESOURCE_ID=volc.service_type.10053
# VOLCENGINE_AST_ENDPOINT=wss://openspeech.bytedance.com/api/v4/ast/v2/translate
